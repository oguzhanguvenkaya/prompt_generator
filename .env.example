# Core API keys
OPENAI_API_KEY=your_openai_api_key
COHERE_API_KEY=your_cohere_api_key

# Database (Neon/Postgres)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Optional: cap research_new prompts per model during seed.
# If unset, seed loads ALL research_new prompts.
# Use only for manual throttling in local/dev runs.
RESEARCH_NEW_PER_MODEL=
